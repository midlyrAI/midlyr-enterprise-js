{
  "name": "@midlyr/sdk-js",
  "version": "0.1.0",
  "description": "MidLyr Enterprise TypeScript SDK for REST APIs.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo -b",
    "typecheck": "tsgo -b --noEmit --pretty false",
    "test": "vitest run --config vitest.config.ts"
  },
  "engines": {
    "node": ">=22"
  }
}
