{
  "name": "@midlyr/cli",
  "version": "0.1.2",
  "description": "MidLyr CLI package scaffold.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "midlyr": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo -b",
    "typecheck": "pnpm --filter @midlyr/sdk-js build && tsgo -b --noEmit --pretty false",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@midlyr/sdk-js": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
